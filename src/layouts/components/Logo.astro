---
import config from "@/config/config.json";
import { Image } from "astro:assets";

const { src, srcDarkmode }: { src?: string; srcDarkmode?: string } =
  Astro.props;
const {
  logo,
  logo_darkmode,
  logo_width,
  logo_height,
  logo_text,
  logo_wordmark,
  logo_wordmark_color,
  title,
}: {
  logo: string;
  logo_darkmode: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  logo_wordmark: string;
  logo_wordmark_color: string;
  title: string;
} = config.site;

const { theme_switcher }: { theme_switcher: boolean } = config.settings;
const markLabel = logo_wordmark || logo_text || title;
---

<a href="/" class="navbar-brand app-header-logo-mark inline-flex items-center gap-1.5">
  {
    src || srcDarkmode || logo || logo_darkmode ? (
      <>
        <Image
          src={src ? src : logo}
          class={`inline-block ${theme_switcher && "dark:hidden"}`}
          width={logo_width.replace("px", "") * 2}
          height={logo_height.replace("px", "") * 2}
          alt=""
          style={{
            height: logo_height.replace("px", "") + "px",
            width: logo_width.replace("px", "") + "px",
            objectFit: "contain",
            background: "rgba(0,0,0,0)",
          }}
          format="webp"
          loading="eager"
        />
        {theme_switcher && (
          <Image
            src={srcDarkmode ? srcDarkmode : logo_darkmode}
            class={"hidden dark:inline-block"}
            width={logo_width.replace("px", "") * 2}
            height={logo_height.replace("px", "") * 2}
            alt=""
            style={{
              height: logo_height.replace("px", "") + "px",
              width: logo_width.replace("px", "") + "px",
              objectFit: "contain",
              background: "rgba(0,0,0,0)",
            }}
            format="webp"
            loading="eager"
          />
        )}
        <span
          class="app-header-logo-wordmark font-secondary leading-none whitespace-nowrap"
          style={{ color: logo_wordmark_color }}
          aria-hidden="true"
        >
          {markLabel}
        </span>
      </>
    ) : markLabel ? (
      <span
        class="app-header-logo-wordmark font-secondary leading-none whitespace-nowrap"
        style={{ color: logo_wordmark_color }}
      >
        {markLabel}
      </span>
    ) : (
      title
    )
  }
</a>
